# AI史学工具 - .gitignore 配置文件

# ===========================================
# 敏感信息 - 绝对不要上传
# ===========================================
secrets/
secrets/**
secret/
secret/**
*.pem
*.key
.env
.env.local
.env.*.local

# API密钥文件
api_key.txt
api_keys.txt
**/api_key.txt
**/api_keys.txt
config/api_config.json
config/current_environment.json
config/external_config.json
config/*.local.json

# ===========================================
# Python 相关
# ===========================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# 虚拟环境
venv/
ENV/
env/
.venv/
.venv*/
*_venv/
.runtime/
dist-windows/
TraeAI-*/

# ===========================================
# IDE 和编辑器
# ===========================================
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# ===========================================
# 日志和临时文件
# ===========================================
*.log
logs/
*.tmp
*.temp
.cache/

# ===========================================
# 数据文件
# ===========================================
data/output/
data/logs/
*.pdf
*.docx
*.doc
*.xlsx
*.xls
*.pptx
*.ppt

# 但保留示例文件
!data/input/test_pdf/
!data/dictionaries/

# ===========================================
# 训练相关 - 不上传
# ===========================================
training_output*/
training_workflow_output/
data/training_data_final/
data/training_output_v*/
*.pth
*.pt
*.h5
*.pkl
*.pickle
*.onnx

# ===========================================
# 归档目录
# ===========================================
archives/
archive/

# ===========================================
# 系统文件
# ===========================================
.DS_Store
Thumbs.db
desktop.ini

# ===========================================
# 测试相关
# ===========================================
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# ===========================================
# Jupyter Notebook
# ===========================================
.ipynb_checkpoints/

# ===========================================
# MyPy
# ===========================================
.mypy_cache/
.dmypy.json
dmypy.json

# ===========================================
# 外部工具 - 不上传
# ===========================================
# external目录下的所有内容都不上传，但保留README.md
external/*
!external/README.md

# 具体排除项（兼容旧配置）
ndlocr-lite/
ndl-search/
external/ndlkotenocr-lite/
external/ndlkotenocr-lite/ocrenv/
external/ndlkotenocr-lite/ndlkotenocr-lite-gui/build/
external/ndlkotenocr-lite/ndlkotenocr-lite-gui/src/
external/ndlkotenocr-lite/ndlkotenocr-lite-gui/userconf.yaml
external/ndlkotenocr-lite/ndlkotenocr-lite-gui/debug.log

# Dify和Ragflow完整排除
external/dify/
external/ragflow/

# ===========================================
# Open Source Finder 存储目录
# ===========================================
open_source_finder/storage/documents/
open_source_finder/storage/cache/
open_source_finder/storage/**/*.pdf
open_source_finder/storage/**/*.md
!open_source_finder/storage/.gitkeep
!open_source_finder/storage/README.md

# ===========================================
# 前端相关 - Node.js
# ===========================================
node_modules/
node_modules/**
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# 前端构建输出
frontend/dist/
frontend/build/
frontend/.vite/

# 前端依赖锁文件（可选，根据团队约定）
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# 前端环境配置
frontend/.env
frontend/.env.local
frontend/.env.*.local

# 前端缓存
frontend/.cache/
frontend/node_modules/.cache/

# TypeScript编译输出
*.tsbuildinfo
*.print.html

# ===========================================
# 浏览器自动化
# ===========================================
selenium/
webdriver/
*.crx
*.crdownload

# ===========================================
# 大型二进制文件
# ===========================================
*.zip
*.tar.gz
*.rar
*.7z
*.iso
*.dmg
*.exe
*.msi

# ===========================================
# Local research materials and run artifacts - never upload
# Keep source code, tests, and documentation separate from papers,
# downloaded sources, OCR outputs, screenshots, checkpoints, and reports.
# ===========================================
output/
ocr_output/
workflow_output/
training_workflow_output/
cache/
tmp/
temp/
downloads/
test_downloads/
organized_books/
local_research_data/
research_data/
private_data/
input_documents/
reference_documents/
materials/
sources/
corpus/

# Historical citation verification artifacts
historical_citation_*run*/
historical_citation_*probe*/
historical_citation_*spotcheck*/
page_map_*/
split_pages/
spread_scan_*/
ocr_page_*/
*_checkpoint.json
*checkpoint*.json
page_mapping_cache.json
verification_results.json
verification_report.md
partial_resume_report.md
resume_checkpoint.json
tmp_ndl_response.xml

# Browser/OpenClaw/NDL session artifacts
browser_screenshots/
openclaw_downloads/
ndl_browser_*/
*.crdownload
*cid_state*.png
cookies*.json
session*.json
storage_state*.json

# Local backups and generated research tables
*.bak
*.csv
*.jsonl
~$*

# Local historical citation model policy generated from machine-specific Ollama evaluations
config/historical_citation_ollama_model_policy.json
config/historical_citation_contained_sources.json
