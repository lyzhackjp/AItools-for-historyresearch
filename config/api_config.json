{
  "_comment": "AI history research tools public configuration template. Keep real API keys, tokens, cookies, NDL credentials, and private paths outside tracked files.",
  "_version": "1.0.1",
  "_created": "2026-04-28",
  "_description": "Tracked production defaults with environment-variable references only.",
  "environment": {
    "name": "production",
    "mode": "production",
    "debug": false
  },
  "api": {
    "base_settings": {
      "timeout": 60,
      "connect_timeout": 10,
      "read_timeout": 60,
      "max_retries": 3,
      "retry_delay": 1.0,
      "retry_backoff_factor": 2.0
    },
    "headers": {
      "User-Agent": "AI-History-Research-Tools/1.0",
      "Accept": "application/json",
      "Content-Type": "application/json",
      "Accept-Encoding": "gzip, deflate"
    },
    "authentication": {
      "api_key": {
        "enabled": true,
        "source": "environment_variable"
      }
    },
    "rate_limiting": {
      "enabled": true,
      "requests_per_minute": 60,
      "requests_per_second": 10,
      "burst_size": 20
    }
  },
  "authentication": {
    "methods": {
      "api_key": {
        "enabled": true,
        "env_var": "API_KEY"
      },
      "oauth": {
        "enabled": false
      },
      "bearer_token": {
        "enabled": false
      }
    },
    "security": {
      "encrypt_api_keys": true,
      "secure_storage": true,
      "key_rotation_days": 90
    }
  },
  "providers": {
    "openai": {
      "enabled": true,
      "base_url": "https://api.openai.com/v1",
      "default_model": "gpt-4o-mini",
      "available_models": ["gpt-4o-mini", "gpt-4o"],
      "api_key_env": "OPENAI_API_KEY",
      "organization": "",
      "stream": true,
      "temperature_range": [0.0, 2.0]
    },
    "dashscope": {
      "enabled": true,
      "base_url": "https://dashscope.aliyuncs.com/api/v1",
      "default_model": "qwen-turbo",
      "available_models": ["qwen-turbo", "qwen-plus", "qwen-max", "qwen-long"],
      "api_key_env": "DASHSCOPE_API_KEY",
      "stream": true,
      "temperature_range": [0.0, 1.0],
      "max_tokens": 8000
    },
    "minimax": {
      "enabled": true,
      "base_url": "https://api.minimax.chat/v1",
      "default_model": "abab6-chat",
      "available_models": ["abab6-chat"],
      "api_key_env": "MINIMAX_API_KEY",
      "group_id_env": "MINIMAX_GROUP_ID",
      "stream": true,
      "temperature_range": [0.0, 1.0]
    },
    "anthropic": {
      "enabled": true,
      "base_url": "https://api.anthropic.com/v1",
      "default_model": "claude-3-haiku-20240307",
      "available_models": ["claude-3-haiku-20240307", "claude-3-sonnet-20240229"],
      "api_key_env": "ANTHROPIC_API_KEY",
      "stream": true,
      "temperature_range": [0.0, 1.0],
      "max_tokens": 4096
    },
    "gemini": {
      "enabled": true,
      "base_url": "https://generativelanguage.googleapis.com/v1beta",
      "default_model": "gemini-pro",
      "available_models": ["gemini-pro"],
      "api_key_env": "GEMINI_API_KEY",
      "stream": true,
      "temperature_range": [0.0, 1.0]
    },
    "deepseek": {
      "enabled": true,
      "base_url": "https://api.deepseek.com",
      "default_model": "deepseek-chat",
      "available_models": ["deepseek-chat", "deepseek-coder"],
      "api_key_env": "DEEPSEEK_API_KEY",
      "stream": true,
      "temperature_range": [0.0, 2.0]
    },
    "volcano": {
      "enabled": true,
      "base_url": "https://ark.cn-beijing.volces.com/api/v3",
      "default_model": "doubao-seed-1-8-251228",
      "available_models": ["doubao-seed-1-8-251228"],
      "api_key_env": "VOLCANO_API_KEY",
      "endpoint_id_env": "VOLCANO_ENDPOINT_ID",
      "stream": true,
      "temperature_range": [0.0, 1.0]
    },
    "ollama": {
      "enabled": true,
      "base_url": "http://localhost:11434",
      "default_model": "qwen36-27b-academic",
      "available_models": ["qwen36-27b-academic", "gemma4-31b-reason", "gemma4:e4b", "bge-m3", "qwen3-embedding:0.6b"],
      "stream": true,
      "temperature_range": [0.0, 1.0]
    }
  },
  "modules": {
    "academic_note_generator": {
      "provider": "ollama",
      "model": "qwen36-27b-academic",
      "temperature": 0.3,
      "max_tokens": 4096,
      "test_mode": false
    },
    "academic_summarizer": {
      "provider": "ollama",
      "model": "qwen36-27b-academic",
      "temperature": 0.2,
      "max_tokens": 4096,
      "test_mode": false
    },
    "virtual_persona_chatbot": {
      "provider": "ollama",
      "model": "gemma4-31b-reason",
      "temperature": 0.7,
      "max_tokens": 4096,
      "test_mode": false
    },
    "style_transfer": {
      "provider": "ollama",
      "model": "qwen36-27b-academic",
      "temperature": 0.4,
      "max_tokens": 4096,
      "test_mode": false
    },
    "ner_processor": {
      "provider": "ollama",
      "model": "qwen36-27b-academic",
      "temperature": 0.1,
      "max_tokens": 2000,
      "test_mode": false
    },
    "embedding_manager": {
      "provider": "ollama",
      "model": "bge-m3",
      "temperature": 0.0,
      "max_tokens": 512,
      "test_mode": false
    },
    "historical_citation_workspace": {
      "provider": "local_rules",
      "model": null,
      "backend": "script",
      "default_action": "parse",
      "search_ndl_default": false,
      "download_source_default": false,
      "restricted_download_default": false
    }
  },
  "logging": {
    "level": "INFO",
    "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s",
    "file": "logs/api.log",
    "max_bytes": 10485760,
    "backup_count": 5,
    "log_api_requests": true,
    "log_api_responses": false
  },
  "monitoring": {
    "enabled": true,
    "track_latency": true,
    "track_errors": true,
    "track_costs": false,
    "alert_thresholds": {
      "latency_ms": 10000,
      "error_rate": 0.05
    }
  }
}
