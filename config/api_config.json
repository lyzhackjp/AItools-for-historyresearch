{
  "_comment": "AI史学工具 - 生产环境API配置文件",
  "_version": "1.0.0",
  "_created": "2026-03-28",
  "_description": "统一管理所有模块的API配置，包含认证、超时、重试等核心设置",
  
  "environment": {
    "name": "production",
    "mode": "production",
    "debug": false,
    "_comment": "环境名称：production/development/test"
  },
  
  "api": {
    "_comment": "API通用配置项",
    
    "base_settings": {
      "timeout": 60,
      "_timeout_comment": "请求超时时间（秒），范围：10-300",
      "connect_timeout": 10,
      "_connect_timeout_comment": "连接超时时间（秒）",
      "read_timeout": 60,
      "_read_timeout_comment": "读取超时时间（秒）",
      "max_retries": 3,
      "_max_retries_comment": "最大重试次数，范围：0-10",
      "retry_delay": 1.0,
      "_retry_delay_comment": "重试延迟时间（秒）",
      "retry_backoff_factor": 2.0,
      "_retry_backoff_factor_comment": "指数退避因子"
    },
    
    "headers": {
      "User-Agent": "AI-History-Research-Tools/1.0",
      "_User-Agent_comment": "用户代理标识",
      "Accept": "application/json",
      "_Accept_comment": "接受的响应格式",
      "Content-Type": "application/json",
      "_Content-Type_comment": "请求内容类型",
      "Accept-Encoding": "gzip, deflate",
      "_Accept-Encoding_comment": "接受的编码格式"
    },
    
    "rate_limiting": {
      "enabled": true,
      "_enabled_comment": "是否启用速率限制",
      "requests_per_minute": 60,
      "_requests_per_minute_comment": "每分钟请求数限制，范围：1-1000",
      "requests_per_second": 10,
      "_requests_per_second_comment": "每秒请求数限制",
      "burst_size": 20,
      "_burst_size_comment": "突发请求大小"
    }
  },
  
  "authentication": {
    "_comment": "认证配置",
    
    "methods": {
      "api_key": {
        "enabled": true,
        "_enabled_comment": "是否启用API密钥认证",
        "env_var": "API_KEY",
        "_env_var_comment": "环境变量名"
      },
      "oauth": {
        "enabled": false,
        "_enabled_comment": "是否启用OAuth认证"
      },
      "bearer_token": {
        "enabled": false,
        "_enabled_comment": "是否启用Bearer Token认证"
      }
    },
    
    "security": {
      "encrypt_api_keys": true,
      "_encrypt_api_keys_comment": "是否加密存储API密钥",
      "secure_storage": true,
      "_secure_storage_comment": "是否使用安全存储",
      "key_rotation_days": 90,
      "_key_rotation_days_comment": "密钥轮换天数"
    }
  },
  
  "providers": {
    "_comment": "各AI服务提供商的配置",
    
    "openai": {
      "_comment": "OpenAI配置",
      "enabled": true,
      "base_url": "https://api.openai.com/v1",
      "_base_url_comment": "API基础URL",
      "default_model": "gpt-4",
      "_default_model_comment": "默认模型",
      "available_models": [
        "gpt-4",
        "gpt-4-turbo",
        "gpt-3.5-turbo"
      ],
      "api_key_env": "OPENAI_API_KEY",
      "_api_key_env_comment": "API密钥环境变量名",
      "organization": "",
      "_organization_comment": "组织ID（可选）",
      "stream": true,
      "_stream_comment": "是否启用流式响应",
      "temperature_range": [0.0, 2.0],
      "_temperature_range_comment": "温度参数范围"
    },
    
    "dashscope": {
      "_comment": "阿里云通义千问配置（推荐）",
      "enabled": true,
      "base_url": "https://dashscope.aliyuncs.com/api/v1",
      "_base_url_comment": "API基础URL",
      "default_model": "qwen-turbo",
      "_default_model_comment": "默认模型",
      "available_models": [
        "qwen-turbo",
        "qwen-plus",
        "qwen-max",
        "qwen-long"
      ],
      "api_key_env": "DASHSCOPE_API_KEY",
      "_api_key_env_comment": "API密钥环境变量名",
      "stream": true,
      "_stream_comment": "是否启用流式响应",
      "temperature_range": [0.0, 1.0],
      "_temperature_range_comment": "温度参数范围",
      "max_tokens": 8000,
      "_max_tokens_comment": "最大生成token数"
    },
    
    "minimax": {
      "_comment": "MiniMax配置",
      "enabled": true,
      "base_url": "https://api.minimax.chat/v1",
      "_base_url_comment": "API基础URL",
      "default_model": "abab6-chat",
      "_default_model_comment": "默认模型",
      "available_models": [
        "abab6-chat",
        "abab5.5-chat",
        "abab5-chat"
      ],
      "api_key_env": "MINIMAX_API_KEY",
      "_api_key_env_comment": "API密钥环境变量名",
      "group_id_env": "MINIMAX_GROUP_ID",
      "_group_id_env_comment": "Group ID环境变量名",
      "stream": true,
      "_stream_comment": "是否启用流式响应",
      "temperature_range": [0.0, 1.0],
      "_temperature_range_comment": "温度参数范围"
    },
    
    "anthropic": {
      "_comment": "Anthropic Claude配置",
      "enabled": true,
      "base_url": "https://api.anthropic.com/v1",
      "_base_url_comment": "API基础URL",
      "default_model": "claude-3-sonnet-20240229",
      "_default_model_comment": "默认模型",
      "available_models": [
        "claude-3-opus-20240229",
        "claude-3-sonnet-20240229",
        "claude-3-haiku-20240307"
      ],
      "api_key_env": "ANTHROPIC_API_KEY",
      "_api_key_env_comment": "API密钥环境变量名",
      "stream": true,
      "_stream_comment": "是否启用流式响应",
      "temperature_range": [0.0, 1.0],
      "_temperature_range_comment": "温度参数范围",
      "max_tokens": 4096,
      "_max_tokens_comment": "最大生成token数"
    },
    
    "gemini": {
      "_comment": "Google Gemini配置",
      "enabled": true,
      "base_url": "https://generativelanguage.googleapis.com/v1beta",
      "_base_url_comment": "API基础URL",
      "default_model": "gemini-pro",
      "_default_model_comment": "默认模型",
      "available_models": [
        "gemini-pro",
        "gemini-pro-vision",
        "gemini-1.5-pro"
      ],
      "api_key_env": "GEMINI_API_KEY",
      "_api_key_env_comment": "API密钥环境变量名",
      "stream": true,
      "_stream_comment": "是否启用流式响应",
      "temperature_range": [0.0, 1.0],
      "_temperature_range_comment": "温度参数范围"
    },
    
    "deepseek": {
      "_comment": "DeepSeek配置",
      "enabled": true,
      "base_url": "https://api.deepseek.com",
      "_base_url_comment": "API基础URL",
      "default_model": "deepseek-chat",
      "_default_model_comment": "默认模型",
      "available_models": [
        "deepseek-chat",
        "deepseek-coder"
      ],
      "api_key_env": "DEEPSEEK_API_KEY",
      "_api_key_env_comment": "API密钥环境变量名",
      "stream": true,
      "_stream_comment": "是否启用流式响应",
      "temperature_range": [0.0, 2.0],
      "_temperature_range_comment": "温度参数范围"
    },
    
    "volcano": {
      "_comment": "火山引擎配置",
      "enabled": true,
      "base_url": "https://ark.cn-beijing.volces.com/api/v3",
      "_base_url_comment": "API基础URL",
      "default_model": "doubao-seed-1-8-251228",
      "_default_model_comment": "默认模型",
      "available_models": [
        "doubao-seed-1-8-251228",
        "doubao-pro-32k"
      ],
      "api_key_env": "VOLCANO_API_KEY",
      "_api_key_env_comment": "API密钥环境变量名",
      "endpoint_id_env": "VOLCANO_ENDPOINT_ID",
      "_endpoint_id_env_comment": "接入点ID环境变量名",
      "stream": true,
      "_stream_comment": "是否启用流式响应",
      "temperature_range": [0.0, 1.0],
      "_temperature_range_comment": "温度参数范围"
    },
    
    "ollama": {
      "_comment": "Ollama本地部署配置",
      "enabled": true,
      "base_url": "http://localhost:11434",
      "_base_url_comment": "本地API基础URL",
      "default_model": "llama2",
      "_default_model_comment": "默认模型",
      "available_models": [
        "llama2",
        "llama3",
        "qwen",
        "mistral"
      ],
      "stream": true,
      "_stream_comment": "是否启用流式响应",
      "temperature_range": [0.0, 2.0],
      "_temperature_range_comment": "温度参数范围",
      "keep_alive": "5m",
      "_keep_alive_comment": "模型保持加载时间"
    }
  },
  
  "modules": {
    "_comment": "各模块的特定配置",
    
    "academic_note_generator": {
      "provider": "dashscope",
      "_provider_comment": "默认使用通义千问",
      "model": "qwen-turbo",
      "temperature": 0.3,
      "_temperature_comment": "生成温度，控制创造性",
      "max_tokens": 2000,
      "_max_tokens_comment": "最大生成token数",
      "test_mode": false,
      "_test_mode_comment": "是否启用测试模式（使用模拟数据）"
    },
    
    "academic_summarizer": {
      "provider": "dashscope",
      "model": "qwen-turbo",
      "temperature": 0.3,
      "max_tokens": 1500,
      "test_mode": false
    },
    
    "virtual_persona_chatbot": {
      "provider": "dashscope",
      "model": "qwen-plus",
      "_model_comment": "使用更强的模型进行对话",
      "temperature": 0.7,
      "_temperature_comment": "较高的温度保持角色一致性",
      "max_tokens": 2000,
      "test_mode": false
    },
    
    "style_transfer": {
      "provider": "dashscope",
      "model": "qwen-turbo",
      "temperature": 0.3,
      "max_tokens": 3000,
      "test_mode": false
    },
    
    "ner_processor": {
      "provider": "dashscope",
      "model": "qwen-turbo",
      "temperature": 0.1,
      "_temperature_comment": "低温度确保准确性",
      "max_tokens": 1000,
      "test_mode": false
    },
    
    "embedding_manager": {
      "_comment": "嵌入模型配置",
      "default_model": "bge-m3",
      "_default_model_comment": "默认嵌入模型",
      "available_models": [
        "bge-m3",
        "qwen3-embedding",
        "voyage-3-large",
        "text-embedding-3-large",
        "ollama-local"
      ],
      "dimension": 1024,
      "_dimension_comment": "向量维度",
      "batch_size": 32,
      "_batch_size_comment": "批处理大小"
    }
  },
  
  "logging": {
    "_comment": "日志配置",
    
    "level": "INFO",
    "_level_comment": "日志级别：DEBUG/INFO/WARNING/ERROR",
    "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s",
    "_format_comment": "日志格式",
    "file": "logs/api.log",
    "_file_comment": "日志文件路径",
    "max_bytes": 10485760,
    "_max_bytes_comment": "日志文件最大大小（10MB）",
    "backup_count": 5,
    "_backup_count_comment": "保留的备份文件数",
    "log_api_requests": true,
    "_log_api_requests_comment": "是否记录API请求",
    "log_api_responses": false,
    "_log_api_responses_comment": "是否记录API响应（可能包含敏感信息）"
  },
  
  "monitoring": {
    "_comment": "监控配置",
    
    "enabled": true,
    "track_latency": true,
    "_track_latency_comment": "是否追踪延迟",
    "track_errors": true,
    "_track_errors_comment": "是否追踪错误",
    "track_costs": true,
    "_track_costs_comment": "是否追踪成本",
    "alert_thresholds": {
      "latency_ms": 5000,
      "_latency_ms_comment": "延迟告警阈值（毫秒）",
      "error_rate": 0.05,
      "_error_rate_comment": "错误率告警阈值"
    }
  }
}
